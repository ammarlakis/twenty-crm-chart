{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "timezone": "Europe/Berlin",
  "schedule": ["before 6am on monday"],
  "dependencyDashboard": true,
  "semanticCommits": "enabled",
  "rangeStrategy": "bump",
  "pinDigests": true,
  "labels": ["dependencies"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/twenty\\/Chart\\.yaml$/"],
      "matchStrings": ["appVersion:\\s*(?<currentValue>\\S+)"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "twentycrm/twenty"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "semanticCommitType": "ci",
      "pinDigests": true
    },
    {
      "matchManagers": ["helm-values"],
      "groupName": "Helm values images",
      "semanticCommitType": "build",
      "pinDigests": true
    },
    {
      "matchPackageNames": ["twentycrm/twenty"],
      "groupName": "Twenty CRM image",
      "semanticCommitType": "build",
      "pinDigests": true
    },
    {
      "matchUpdateTypes": ["digest"],
      "groupName": "Dependency digests",
      "semanticCommitType": "build"
    }
  ]
}
