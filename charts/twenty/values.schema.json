{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "required": ["serverUrl", "database", "redisUrl"],
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "commonLabels": {
      "type": "object"
    },
    "commonAnnotations": {
      "type": "object"
    },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array"
    },
    "serverUrl": {
      "type": "string",
      "minLength": 1
    },
    "frontend": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "overrideServerBaseUrl": {
          "type": "boolean"
        },
        "serverBaseUrl": {
          "type": "string"
        }
      },
      "if": {
        "properties": {
          "overrideServerBaseUrl": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "serverBaseUrl": {
            "minLength": 1
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "automount": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "server": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "podAnnotations": {
          "type": "object"
        },
        "podLabels": {
          "type": "object"
        },
        "service": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "annotations": {
              "type": "object"
            },
            "labels": {
              "type": "object"
            }
          }
        },
        "persistence": {
          "$ref": "#/definitions/persistence"
        },
        "dockerDataPersistence": {
          "$ref": "#/definitions/persistence"
        },
        "resources": {
          "type": "object"
        },
        "env": {
          "type": "object"
        },
        "extraEnv": {
          "type": "array"
        },
        "envFrom": {
          "type": "array"
        },
        "securityContext": {
          "type": "object"
        },
        "livenessProbe": {
          "type": "object"
        },
        "readinessProbe": {
          "type": "object"
        },
        "startupProbe": {
          "type": "object"
        }
      }
    },
    "worker": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "podAnnotations": {
          "type": "object"
        },
        "podLabels": {
          "type": "object"
        },
        "command": {
          "type": "array",
          "minItems": 1
        },
        "resources": {
          "type": "object"
        },
        "env": {
          "type": "object"
        },
        "extraEnv": {
          "type": "array"
        },
        "envFrom": {
          "type": "array"
        },
        "securityContext": {
          "type": "object"
        }
      }
    },
    "migrations": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "podAnnotations": {
          "type": "object"
        },
        "podLabels": {
          "type": "object"
        },
        "command": {
          "type": "array",
          "minItems": 1
        },
        "backoffLimit": {
          "type": "integer",
          "minimum": 0
        },
        "ttlSecondsAfterFinished": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "resources": {
          "type": "object"
        },
        "securityContext": {
          "type": "object"
        }
      }
    },
    "database": {
      "type": "object",
      "required": ["host", "passwordSecret"],
      "additionalProperties": true,
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "user": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "passwordSecret": {
          "type": "object",
          "required": ["name", "key"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "key": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "redisUrl": {
      "type": "string",
      "minLength": 1
    },
    "secrets": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "encryption": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "existingSecret": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "key": {
              "type": "string",
              "minLength": 1
            },
            "encryptionKey": {
              "type": "string"
            },
            "fallbackEncryptionKey": {
              "type": "string"
            }
          }
        }
      }
    },
    "podSecurityContext": {
      "type": "object"
    },
    "podAnnotations": {
      "type": "object"
    },
    "podLabels": {
      "type": "object"
    },
    "priorityClassName": {
      "type": "string"
    },
    "runtimeClassName": {
      "type": "string"
    },
    "nodeSelector": {
      "type": "object"
    },
    "tolerations": {
      "type": "array"
    },
    "affinity": {
      "type": "object"
    },
    "topologySpreadConstraints": {
      "type": "array"
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "type": "object"
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["host", "paths"],
            "properties": {
              "host": {
                "type": "string",
                "minLength": 1
              },
              "paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "pathType": {
                      "type": "string",
                      "enum": ["Exact", "Prefix", "ImplementationSpecific"]
                    }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array"
        }
      },
      "if": {
        "properties": {
          "enabled": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "hosts": {
            "minItems": 1
          }
        }
      }
    }
  },
  "definitions": {
    "persistence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "size": {
          "type": "string",
          "minLength": 1
        },
        "storageClass": {
          "type": "string"
        },
        "accessModes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
